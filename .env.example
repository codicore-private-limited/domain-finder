# Copy to .env and fill in. Never commit real secrets.

# Required
DATABASE_URL=******host:5432/dbname

# Server
PORT=8080
NODE_ENV=development

# Optional integrations
GROQ_API_KEY=
GODADDY_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Force TLS for Postgres even if URL doesn't include sslmode=require
# PGSSL=require

# ── Quality / diamond gate ───────────────────────────────────────────────────
# Minimum score (0-100) for a name to be classified as isDiamond=true.
# Raise to be stricter (fewer diamonds); lower to surface more candidates.
# DIAMOND_THRESHOLD=88

# Maximum valueScore for a two-word combo containing a weak/generic filler
# noun (tab, tile, ratio, rack, tube, mode, panel…) that is NOT a recognised
# high-value commercial category phrase.
# WEAK_NOUN_MAX_SCORE=65

# Maximum valueScore for a single-segment weak noun (not a two-word combo).
# WEAK_NOUN_SINGLE_MAX_SCORE=75

# Minimum demand score (0-100) required for a corpus bigram phrase to be
# included in the real-phrases pool at all.
# MIN_PHRASE_DEMAND=0

# Demand score threshold above which a known real phrase qualifies as a
# high-value commercial category (eligible for diamond grade).
# HIGH_VALUE_PHRASE_DEMAND_THRESHOLD=85

# ── Hunter loop ──────────────────────────────────────────────────────────────
# Number of names probed (DNS + RDAP) per hunter cycle.
# HUNTER_BATCH_SIZE=5000

# Maximum simultaneous DNS connections.
# HUNTER_CONCURRENCY=800

# How long (ms) before a previously-checked name is eligible for a re-probe.
# Default 10 minutes (600000 ms). Reduce to catch expirations faster at the
# cost of higher DNS traffic.
# HUNTER_RECHECK_MS=600000

# ── Diversity / flooding prevention ─────────────────────────────────────────
# Maximum number of entries sharing the same FIRST word/stem that may appear
# in the Verb+Noun / Noun+Noun combinatorial pool.  Prevents hundreds of
# lane*, mode*, vote* variants from flooding the results.
# DIVERSITY_PREFIX_CAP=25

# Maximum number of entries sharing the same SECOND word/stem in the pool.
# DIVERSITY_SUFFIX_CAP=25
