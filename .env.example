77# Copy to .env and fill in. Never commit real secrets.

# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=8080
NODE_ENV=development

# Optional integrations
GROQ_API_KEY=
GODADDY_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Force TLS for Postgres even if URL doesn't include sslmode=require
# PGSSL=require
